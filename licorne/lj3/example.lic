
class LJ3(
    var x: [0..],
    var y: [0..100],
    var z: Int with it % 2 == 0 && it >= 0 || it % 2 != 0 && it < 0   //> LJ3::ternary-ref p=(0,0,0/0) r=(1,1/1)  --  Licorne does not allow type predicates to contains ternaries, but we can express the same using this convoluted formula
) {

    fn absDiv_correct(this, a: Int, b: Int with it != 0) -> [0..] {     //> LJ3::absDiv_correct p=(2,1,1/1) r=(1,1/1)
        val res = a / b;
        return when res >= 0 then res else -res;
    }

    fn absDiv_buggy(this, a: Int, b: Int) -> [0..] {                    //> LJ3::absDiv_buggy p=(2,0,0/0) r=(1,1/1) BUG
        val res = a / b;
        return when res >= 0 then res else -res;
    }

}
