
class Test(
    var x: [0..],
    var y: [0..100],
    var z: Int with it % 2 == 0 && it >= 0 || it % 2 != 0 && it < 0   // Licorne does not allow type predicates to contains ternaries
) {

    fn absDiv_correct(this, a: Int, b: Int with it != 0) -> [0..] {
        val res = a / b;
        return when res >= 0 then res else -res;
    }

    fn absDiv_buggy(this, a: Int, b: Int) -> [0..] {
        val res = a / b;
        return when res >= 0 then res else -res;
    }

}
