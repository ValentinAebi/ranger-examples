
typealias Nat = [0..]

object Sum {

    fn sum_original(n: Int) -> Nat & [n..] {    //> Sum::sum_original p=(1,0,0/0) r=(2,2/2) BUG REPORTED
        if (n <= 1) {
            return 0;   // ERROR: violates [n..]
        } else {
            val t1 = sum_original(n-1);
            return n + t1;
        }
    }

    fn sum_fixed(n: Int) -> Nat & [n..] {       //> Sum::sum_fixed p=(1,0,0/0) r=(2,2/2)
        if (n < 0) {
            return 0;
        } else if (n <= 1) {
            return n;
        } else {
            val t1 = sum_fixed(n-1);
            return n + t1;
        }
    }

}
