
object Test {

    fn getYear() -> [2021..] = 2024

    fn test_correct() {     //> Test::test_correct p=(0,0,0/0) r=none loc=7
        val a = 1998;
        val c = Cars.newCarWithDefaultValues();
        c.setYear(a);

        val j: [1801..] = c.getYear();      // we ignore these annotations, they are needed only for testing
        val k: [2021..] = getYear();
    }

    fn test_buggy() {       //> Test::test_buggy p=(0,0,0/0) r=none BUG REPORTED loc=7
        val a = 998;
        val c = Cars.newCarWithDefaultValues();
        c.setYear(a);        // ERROR: bad value

        val j: [1801..] = c.getYear();      // we ignore these annotations, they are needed only for testing
        val k: [2021..] = getYear();
    }

}
