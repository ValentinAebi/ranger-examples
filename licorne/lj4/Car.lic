
typealias CarAcceptableYears = [1801 ..< 2050]

class Car(
    var year: CarAcceptableYears,
    var seats: [0..]
) {

    fn setYear(this, year: CarAcceptableYears) {
        this.year = year;
    }

    fn getYear(this) -> CarAcceptableYears = year

}

object Cars {

    fn newCarWithDefaultValues() -> Car {
        return new Car(year = 2026, seats = 5);
    }

}
