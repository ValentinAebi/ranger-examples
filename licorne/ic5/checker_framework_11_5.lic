package checker_framework_examples;

import arrays.Array;

typealias ArrOfSameLen[T,U](arr: Array[U]) = Array[T] with it.length() == arr.length()

object IC5 {

    fn lessThan_correct(a1: Array[Int], a2: ArrOfSameLen[Int](a1)) -> Bool {    //> IC5::lessThan_correct p=(2,1,1/1) r=(0,0/0)
        for (var i = 0; i < a1.length(); i += 1) {
            if (a1.at(i) < a2.at(i)) {
                return true;
            } else if (a1.at(i) > a2.at(i)) {
                return false;
            }
        };
        return false;
    }

    fn lessThan_buggy(a1: Array[Int], a2: ArrOfSameLen[Int](a1)) -> Bool {      //> IC5::lessThan_buggy p=(2,1,1/1) r=(0,0/0) BUG
        for (var i = 0; i < a1.length(); i -= 1) {  // ERROR: should be i += 1
            if (a1.at(i) < a2.at(i)) {
                return true;
            } else if (a1.at(i) > a2.at(i)) {
                return false;
            }
        };
        return false;
    }

    // alternative using explicit precondition
    fn lessThan_v2(arr1: Array[Int], arr2: Array[Int] where arr1.length() == arr2.length()) -> Bool {
        for (var i = 0; i < arr1.length(); i += 1) {
            if (arr1.at(i) < arr2.at(i)) {
                return true;
            } else if (arr1.at(i) > arr2.at(i)) {
                return false;
            }
        };
        return false;
    }

}
