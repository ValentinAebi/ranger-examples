package arrays;

typealias Length = [0..]
typealias Idx[T](array: Array[T]) = [0 ..< array.length()]

class Array[T] {

    pure fn length(this) -> Length {
        panic "compile to bytecode ARRAYLENGTH";
    }

    fn at(this, i: Idx(this)) -> T {
        panic "compile to bytecode xALOAD"
    }

}
