    fn indexOf(s: String, target: String with length(it) <= length(s)) -> [-1 ..< length(s) - length(target)] {
        panic "not implemented"
    }

    fn substring(s: String, from: Position(s), end: Position(s) & [from..]) -> StringOfLen(end - from) {
        panic "not implemented"
    }

    fn concat(s1: String, s2: String) -> StringOfLen(length(s1) + length(s2)) {
        panic "not implemented"
    }

}

