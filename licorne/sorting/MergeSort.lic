// adapted from https://github.com/TheAlgorithms/Java/blob/master/src/main/java/com/thealgorithms/sorts/MergeSort.java

package sorting;

import arrays.Array;
import arrays.Length;
import arrays.Idx;

import sorting.ArrayUtils.arrayCopy;


typealias ArrayOfLen[T](len: Length) = Array[T] with it.length() == len


object MergeSort {

    fn sort[T](array: Array[T], lessThan: fn (T,T) -> Bool) {       //> MergeSort::sort p=(2,0,0/0) r=none
        if (array.length() == 0) {
            return;
        };
        val tmpArray = new Array(length = array.length());
        doSort(array, tmpArray, lessThan, 0, array.length() - 1);
    }

    private fn doSort[T](array: Array[T], tmpArray: ArrayOfLen[T](array.length()),
                         lt: fn (T,T) -> Bool, left: Idx(array), right: Idx(array)) {       //> MergeSort::doSort p=(5,3,8/8) r=none  --  8 constraints here: both left and right must be in bounds for array and tmpArray: 2 indices x 2 arrays x 2 bounds
        if (left < right) {
            val mid = (left + right) / 2;
            doSort(array, tmpArray, lt, left, mid);
            doSort(array, tmpArray, lt, mid + 1, right);
            merge(array, tmpArray, lt, left, mid, right);
        }
    }

    private fn merge[T](array: Array[T], tmpArray: ArrayOfLen[T](array.length()),
                        lt: fn (T,T) -> Bool, left: Idx(array), mid: Idx(array), right: Idx(array) & [left..]) {  //> MergeSort::merge p=(6,5,13/13) r=none BUG REPORTED bypass=1  --  13 constraints here: all of left, mid, and right, need to be valid indices for array and tmpArray: 3 indices x 2 arrays x 2 bounds = 12, plus the constrains left <= right
        var i = left;
        var j = mid + 1;
        arrayCopy(array, left, tmpArray, left, right + 1 - left);

        for (var k = left; k <= right; k += 1) {
            if (j > right) {
                array.set(k, tmpArray.get(i!!));    // hybrid cast
                i += 1;
            } else if (i > mid) {
                array.set(k, tmpArray.get(j));
                j -= 1;     // ERROR: should be j += 1 here
            } else if (lt(tmpArray.get(j), tmpArray.get(i))) {
                array.set(k, tmpArray.get(j));
                j += 1;
            } else {
                array.set(k, tmpArray.get(i));
                i += 1;
            }
        }
    }

}
