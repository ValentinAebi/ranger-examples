package collections.maps;

import collections.Length;
import collections.arrays.Array;
import collections.arrays.ArrayOfSameLength;


// A (fixed-capacity) implementation of an ArrayMap
class ArrayMap[K sub Any, V sub Any](           //> ArrayMap::constructor p=(3,2,3/3) r=none
    keys: Array[K?],
    values: ArrayOfSameLength[V?](keys),
    var currSize: [0 .. capacity()]
) : Map[K, V] {

    pure fn capacity(this) -> Length =          //> ArrayMap::capacity p=(0,0,0/0) r=(1,1/1)
        this.keys.size()

    fn currentSize(this) -> [0 .. capacity()] =     //> ArrayMap::currentSize p=(0,0,0/0) r=(1,2/2)
        this.currSize

    fn get(this, k: K) -> V? {                  //> ArrayMap::get p=(1,0,0/0) r=(0,0/0)
        val idx = this.keys.indexOf(k);
        if (idx == null) {
            return null;
        } else {
            return this.values.get(idx);
        }
    }

    fn put(this, k: K, v: V) -> Bool {          //> ArrayMap::put p=(2,0,0/0) r=(0,0/0) BUG REPORTED
        val preSize = currentSize();
        val canAdd = preSize < capacity();
        if canAdd {
            var stop = false;
            // ERROR: should be < instead of <=
            for (var i = 0; i <= this.keys.size() && !stop; i += 1) {
                if (this.keys.get(i) == null) {
                    this.keys.set(i, k);
                    this.values.set(i, v);
                    stop = true;
                }
            };
            this.currSize = preSize + 1;
        };
        return canAdd;
    }

    fn remove(this, k: K) -> Bool {         //> ArrayMap::remove p=(1,0,0/0) r=(0,0/0)
        val preSize = currentSize();
        if (preSize > 0) {
            val idx = this.keys.indexOf(k);
            if idx == null {
                return false;
            };
            this.keys.set(idx, null);
            this.values.set(idx, null);
            this.currSize = preSize - 1;
            return true;
        };
        return false;
    }

}

object ArrayMaps {

    fn newEmptyOfCapacity[K sub Any, V sub Any](capacity: Length) -> ArrayMap[K, V] =   //> ArrayMap::aux-constructor p=(1,1,1/1) r=none  --  ignoring the (unrefined!) return type since it has no counterpart in the Java implementation
        new ArrayMap(keys = new Array(size = capacity), values = new Array(size = capacity), currSize = 0);

}

