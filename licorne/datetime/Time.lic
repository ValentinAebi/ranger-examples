package datetime;


typealias Hours = [0..23]
typealias Minutes = [0..59]
typealias Seconds = [0..59]


record Time(hours: Hours, minutes: Minutes, seconds: Seconds) {     //> Time::constructor p=(3,3,6/6) r=none

    fn deltaTime(this, h: Int, min: Int, sec: Int) -> Time {        //> Time::deltaTime p=(3,0,0/0) r=(0,0/0)
        val sSum = seconds() + sec;
        val seconds = (sSum % 60 + 60) % 60;
        val mSum = minutes() + min + (sSum - seconds) / 60;
        val minutes = (mSum % 60 + 60) % 60;
        val hSum = hours() + h + (mSum - minutes) / 60;
        val hours = (hSum % 24 + 24) % 24;
        return new Time(hours, minutes, seconds);
    }

    fn deltaHours(this, h: Int) -> Time = deltaTime(h, 0, 0)        //> Time::deltaHours p=(1,0,0/0) r=(0,0/0)

    fn deltaMinutes(this, m: Int) -> Time = deltaTime(0, m, 0)      //> Time::deltaMinutes p=(1,0,0/0) r=(0,0/0)

    fn deltaSeconds(this, s: Int) -> Time = deltaTime(0, 0, s)      //> Time::deltaSeconds p=(1,0,0/0) r=(0,0/0)

}


class MutTime(                                              //> MutTime::constructor p=(3,3,6/6) r=none
    var hours: Hours,
    var minutes: Minutes,
    var seconds: Seconds
) {

    fn moveBy(this, h: Int, m: Int, s: Int) {               //> MutTime::moveBy p=(3,0,0/0) r=none BUG REPORTED
        val sSum = this.seconds + s;
        this.seconds = (sSum % 60 + 60) % 60;
        val mSum = this.minutes + m + (sSum / 60);
        this.minutes = (mSum % 60 + 60) % 60;
        val hSum = this.hours + h + (mSum / 60);
        // ERROR: should be normalized to 24, not 60
        this.hours = (hSum % 60 + 60) % 60;
    }

    fn moveByHours(this, h: Int) {                          //> MutTime::moveByHours p=(1,0,0/0) r=none
        moveBy(h, 0, 0);
    }

    fn moveByMinutes(this, m: Int) {                        //> MutTime::moveByMinutes p=(1,0,0/0) r=none
        moveBy(0, m, 0);
    }

    fn moveBySeconds(this, s: Int) {                        //> MutTime::moveBySeconds p=(1,0,0/0) r=none
        moveBy(0, 0, s);
    }

}
