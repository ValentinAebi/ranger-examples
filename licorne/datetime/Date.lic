package datetime;

import datetime.Dates.nDaysInMonth;

typealias Year = Int
typealias Month = [1..12]
typealias DayOfMonth(year: Year, month: Month) = [1..nDaysInMonth(year, month)]

record Date(year: Year, month: Month, day: DayOfMonth(year, month)) {       //> Date::constructor p=(3,2,4/4) r=none

    pure fn nextDay(this) -> Date {                                         //> Date::nextDay p=(0,0,0/0) r=(0,0/0)
        if (this.day() < nDaysInMonth(this.year(), this.month())) {
            return new Date(year = this.year(), month = this.month(), day = this.day() + 1);
        } else if (this.month() < 12) {
            return new Date(year = this.year(), month = this.month() + 1, day = 1);
        } else {
            return new Date(year = this.year() + 1, month = 1, day = 1);
        }
    }

    pure fn previousDay(this) -> Date {                                     //> Date::previousDay p=(0,0,0/0) r=(0,0/0) BUG
        if (this.day() > 1) {
            return new Date(year = this.year(), month = this.month(), day = this.day() - 1);
        } else if (this.month() > 1) {
            // ERROR: the programmer forgot to update `this.month() + 1` to `this.month() - 1` after copy-pasting from nextDay
            return new Date(year = this.year(), month = this.month() + 1, day = nDaysInMonth(this.year(), this.month() - 1));
        } else {
            return new Date(year = this.year() - 1, month = 12, day = nDaysInMonth(this.year() - 1, 12));
        }
    }

}


object Dates {

    pure fn nDaysInMonth(year: Year, month: Month) -> [28..31] {            //> Date::nDaysInMonth p=(2,1,2/2) r=(1,2/2)
        if (month == 2) {
            // slightly simplified...
            return when year % 4 != 0 then 28
                   else when year % 100 != 0 then 29
                   else when year % 400 != 0 then 28
                   else 29;
        };
        if (month == 1 || month == 3 || month == 5 || month == 7 || month == 8 || month == 10 || month == 12) {
            return 31;
        };
        return 30;
    }

}
