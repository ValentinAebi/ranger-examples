package either;

datatype Either[+L, +R]
record Left[+L](l: L) : Either[L, Nothing]
record Right[+R](r: R) : Either[Nothing, R]

object Eithers {

    fn compute[L, R, T](e: Either[L, R], lf: fn (L) -> T, rf: fn (R) -> T) -> T {
        if e is Left {
            return lf(e.l());
        } else if e is Right {
            return rf(e.r());
        }
    }

}
